{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "Node.js 24 + TypeScript Fastify service with Scalar/OpenAPI docs and structured logging",
  "main": "dist/server.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "node --env-file=.env --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@scalar/fastify-api-reference": "^1.53.1",
    "evlog": "^2.14.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "fastify-zod-openapi": "^5.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0-beta.18"
  }
}
