{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "jsx-a11y"],
  "env": {
    "browser": true,
    "es2021": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "rules": {
    "no-console": "off",
    "react-in-jsx-scope": "off",
    "react/jsx-key": "error",
    "typescript/no-explicit-any": "warn"
  },
  "ignorePatterns": ["dist/**", "node_modules/**"]
}
