{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "node", "vitest"],
  "env": {
    "node": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off"
  },
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "overrides": [
    {
      "files": ["*.test.ts", "*.spec.ts", "src/**/__tests__/**"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
